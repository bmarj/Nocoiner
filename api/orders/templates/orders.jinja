{% extends 'base.jinja' %}

{% block content %}
<div class="row">
    <div class="col-lg-12">
        <div class="card mb-3">
            <div class="card-header">
                <div class="caption uppercase">
                    <i class="ti-layout-grid3-alt"></i> Orders View
                </div>
                <div class="tools">
                  <button class="btn btn-primary btn-add" onclick="goToEditModal(this, '{{ url_for('.edit', id='') }}', '#editModal')">
                    <i class="ti-write mr-1"></i>Edit</button>
                  <button class="btn btn-warning btn-add" onclick="doActionPost(this, '{{ url_for('.cancel_order', id='') }}', '#editModal')"
                    data-confirmation-message="Are you sure you want to cancel this order?">
                    <i class="ti-trash mr-1"></i>Cancel order</button>
                </div>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table id="datatable" class="table table-bordered table-hover clickable-rows" cellspacing="0">
                      <thead class="thead-light"></thead>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- modal dialog placeholder -->
<div class="modal fade" id="editModal" tabindex="-1" role="dialog" aria-labelledby="editModalLabel" aria-hidden="true">
</div>
{% endblock content %}

{% block extra_javascripts %}
  <script>
    let dtConf = defaultDatatablesConfig;

    dtConf.ajax.url = '{{ url_for('.orders_data') }}';

    dtConf.columns = [
        { data:"order_number", title:"Order Number" },
        { data:"purchase_date", title:"Purchase Date" },
        { data:"ship_name", title:"Shipping Name" },
        { data:"ship_address", title:"Shipping Address" },
        { data:"ship_address_2", title:"Shipping Address 2" },
        { data:"ship_city", title:"Shipping City" },
        { data:"ship_state", title:"Shipping State" },
        { data:"shipping_priority", title:"Shipping Priority" },
        { data:"sales_channel.description", title:"Sales Channel" },
    ];

    // this function provides API for modal dialog to refresh source grid
    function table_reload() {
      $('#datatable').DataTable().ajax.reload(null, false);
    };

    $(document).ready(function () {
      tb = initDatatable('#datatable', dtConf);
      /* yadcf.init(tb, [
        { column_number: 0, filter_type: "text", filter_match_mode: 'startsWith' },
      ]); */
    });
  </script>

{% endblock extra_javascripts %}

{# additional features used on this page: #}
{% block feature_javascripts %}
  {% include '_feature_column_visibility.html' %}
  {# {% include '_feature_column_filtering.html' %} #}
{% endblock feature_javascripts %}