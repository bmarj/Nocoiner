{% from "_formhelpers.html" import render_field, validation_summary %}
<div class="modal" id="editModal" tabindex="-1" role="dialog" aria-labelledby="editModalLabel"
    aria-hidden="true" data-backdrop="static" data-focus="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content dialog-size-form">
            <div class="modal-header">
                <h5 class="modal-title" id="editModalLabel">Edit</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <form class="validate {{ classes }}" action="" method="POST" novalidate>
                  <input type="hidden" name="key" value="{{ key }}">
                  {{ form.hidden_tag() }}
                  {{ render_field(form.order_number) }}
                  {{ render_field(form.ship_name) }}
                  {{ render_field(form.ship_phone) }}
                  {{ render_field(form.ship_email) }}
                  {{ render_field(form.ship_address) }}
                  {{ render_field(form.ship_address_2) }}
                  {{ render_field(form.ship_city) }}
                  {{ render_field(form.ship_postal_code) }}
                  {{ render_field(form.ship_country) }}
                  {{ render_field(form.ship_state) }}
                </form>                
            </div>                        
            <div class="modal-footer">                
                {{ validation_summary(form) }}
                <button id="btnUpdate" type="button" class="btn btn-primary"
                        onclick="submitModal(this,'{{ url_for('.update') }}','#editModal');">Save</button>
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
            </div>
        </div>
    </div>
    <script type="text/javascript" charset="utf-8">
      setupModal();
      $('#editModal').modal('show');
    </script>
</div>