{% extends 'base.jinja' %}

{% block content %}
  <div class="row">
      <div class="col-lg-12">
          <div class="card mb-3">
              <div class="card-header">
                  <div class="caption uppercase">
                      <i class="ti-package"></i> Order Lines
                  </div>
                  <div class="tools">
                    <button class="btn btn-primary btn-add" onclick="goToEditModal(this, '/order_lines/edit', '#editModal')"><i class="ti-write mr-1"></i>Edit</button>
                    <button class="btn btn-warning btn-add" onclick="doDelete(this, '/order_lines/delete')"><i class="ti-trash mr-1"></i>Delete</button>
                  </div>
              </div>
              <div class="card-body">
                  <div class="table-responsive">
                      <table id="datatable" class="table table-striped table-bordered table-hover clickable-rows" cellspacing="0">
                      </table>
                  </div>
              </div>
          </div>
      </div>
  </div>
</div>

<!-- modal dialog placeholder -->
<div class="modal fade" id="editModal" tabindex="-1" role="dialog" aria-labelledby="editModalLabel" aria-hidden="true">
</div>
{% endblock content %}

{% block extra_javascripts %}  
  <script type="text/javascript" charset="utf-8">
    $(document).ready(function () {
      var table = $('#datatable')
      .on('draw.dt', function(e, settings, data, xhr) {setupTable();} )
      .DataTable({
        "processing": true,
        "serverSide": true,
        "filter": true,
        "deferRender": true,
        "ajax": "{{ url_for('.order_feedsDT') }}",
        "rowId": 'guid_order_line',
        "columns": [
            { data:"sku", title:"SKU", defaultContent:"", searchable:"false"},
            { data:"order_line_flags.purchase_order_number", title:"PO #", defaultContent:"" },
            { data:"product.brand", title:"Brand", defaultContent:"", searchable:"false", orderable:false, render:cell_template},
        ]
      });
    });

    function cell_template(data, type, row, meta) {
      return type === 'display' ?
          '<b>' + data + '</b>' :
          data;
    };

    function table_reload() {
      $('#datatable').DataTable().ajax.reload(null, false);
    };
  </script>

{% endblock extra_javascripts %}
