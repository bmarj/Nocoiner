<div class="modal" id="editModal" tabindex="-1" role="dialog" aria-labelledby="editModalLabel" aria-hidden="false">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <button type="button" class="close" data-dismiss="modal"><span aria-hidden="true">×</span><span
            class="sr-only">Close</span></button>
        <h4 class="modal-title" id="editModalLabel">Edit</h4>
      </div>
      <form role="form">
        <input type="hidden" name="guid_order_line" value="{{ data.guid_order_line }}">
        <div class="modal-body">
          <div class="form-group">
            <label for="sku" class="control-label">SKU:</label>
            <input type="text" class="form-control" value="{{ data.sku }}">
          </div>
          <div class="form-group">
            <label for="purchase_order_number" class="control-label">PO:</label>
            <input type="text" class="form-control"
              name="purchase_order_number" value="{{ data.order_line_flags.purchase_order_number }}">
          </div>
          <div class="form-group">
            <label for="purchase_order_number" class="control-label">Notes:</label>
            <textarea class="form-control"
              name="notes">{{ data.order_line_flags.notes }}</textarea>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-default" data-dismiss="modal">Close</button>
          <button id="btnUpdate" type="button" class="btn btn-primary"
            onclick="submitModal(this,'/order_lines/update','#editModal');">Update</button>
        </div>
      </form>
    </div>
  </div>
  <script type="text/javascript" charset="utf-8">
    setupModal();
    $('#editModal').modal('show');
  </script>
</div>