{% include 'base.jinja' %}

{% block extra_stylesheets %}
  <link href="https://cdn.datatables.net/1.10.10/css/jquery.dataTables.css" rel="stylesheet">
{% endblock %}

{% block content %}
  <div class="row">
    <div class="col-lg-12">
      <h2>Order Lines</h2>
      <table id="datatable" class="display" cellspacing="0" width="100%">
        <thead>
          <tr>
            <th>SKU</th>
            <th>PO#</th>
            <th>Brand</th>
          </tr>
        </thead>
      <tbody>
      </tbody>
    </table>
  </div>
</div>
{% endblock %}

{% block extra_javascripts %}  
  <script type="text/javascript" charset="utf-8">
    $(document).ready(function () {
      var table = $('#datatable').DataTable({
        "processing": true,
        "serverSide": true,
        "filter": true,
        "deferRender": true,
        "ajax": "{{ url_for('orders_dt.order_feedsDT') }}",
        "rowId": 'guid_order_line',
        "columns": [
            { data: "sku", defaultContent: "", searchable: 'false'},
            { data: "order_line_flags.purchase_order_number", defaultContent: "" },
            { data: "product.brand", defaultContent: "", searchable: 'false', orderable: false, render: cell_template},
        ]
      });
    });

    function cell_template(data, type, row, meta) {
      return type === 'display' ?
          '<b>' + data + '</b>' :
          data;
    };
  </script>
{% endblock %}
