{% extends 'base.jinja' %}

{% block content %}
<div class="row">
    <div class="col-lg-12">
        <div class="card mb-3">
            <div class="card-header">
                <div class="caption uppercase">
                    <i class="ti-user"></i> Permissions View
                </div>
                <div class="tools">
                  {% from "_buttons.html" import add, add_inline, copy, edit, delete %}
                  {{ add_inline('PermissionForm', 'users', current_user) }}
                  {{ delete('PermissionForm', 'users', current_user) }}
                </div>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table id="datatable" class="table table-bordered table-hover clickable-rows" cellspacing="0">
                      <thead class="thead-light"></thead>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

{% endblock content %}

{% block extra_javascripts %}
  <script>
    let dtConf = defaultDatatablesConfig;

    dtConf.ajax.url = '{{ url_for('.permissions_data') }}';

    dtConf.columns = [
        { data:"name", title:"Permission" }
    ];

    $(document).ready(function () {
      initDatatable('#datatable', dtConf);
    });
  </script>

{% endblock extra_javascripts %}

{# additional features used on this page: #}
{% block feature_javascripts %}
{% endblock feature_javascripts %}