{% extends 'base.jinja' %}

{% block content %}
  <div class="row">
      <div class="col-lg-12">
          <div class="card mb-3">
              <div class="card-header">
                  <div class="caption uppercase">
                      <i class="ti-user"></i> Roles - Permission View
                  </div>
                  <div class="tools">
                    {% from "_buttons.html" import add, edit, delete %}
                    {{ add('RolePermissionForm', 'users', current_user) }}
                    {{ edit('RolePermissionForm', 'users', current_user) }}
                    {{ delete('RolePermissionForm', 'users', current_user) }}
                  </div>
              </div>
              <div class="card-body">
                  <div class="table-responsive">
                      <table id="datatable" class="table table-bordered table-hover clickable-rows" cellspacing="0">
                        <thead class="thead-light"></thead>
                      </table>
                  </div>
              </div>
          </div>
      </div>
  </div>
</div>

<!-- modal dialog placeholder -->
<div class="modal fade" id="editModal" tabindex="-1" role="dialog" aria-labelledby="editModalLabel" aria-hidden="true">
</div>
{% endblock content %}

{% block extra_javascripts %}  
  <script>
    let dtConf = defaultDatatablesConfig;

    dtConf.ajax.url = '{{ url_for('.role_permissions_data') }}';

    dtConf.columns = [        
        { data:"role.name", title:"Role" },
        { data:"permission.name", title:"Permission" },
    ];

    // this function provides API for modal dialog to refresh source grid
    function table_reload() {
      $('#datatable').DataTable().ajax.reload(null, false);
    };

    $(document).ready(function () {
      initDatatable('#datatable', dtConf);
    });
  </script>

{% endblock extra_javascripts %}

{# additional features used on this page: #}
{% block feature_javascripts %}
{% endblock feature_javascripts %}