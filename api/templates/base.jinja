<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1" />
    <meta content='width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=0' name='viewport' />
    <meta name="viewport" content="width=device-width" />

    <title>
        Nocoiner - Binance leaderboard trades
    </title>

    <link rel="stylesheet" href="/static/siqtheme.css">
    <link rel="stylesheet" href="https://code.jquery.com/ui/1.11.3/themes/smoothness/jquery-ui.css">
    {% block extra_stylesheets %} {% endblock extra_stylesheets %}
    <link rel="stylesheet" href="/static/app.css">
    <link rel="apple-touch-icon" sizes="76x76" href="/static/img/apple-icon.png">
    <link rel="icon" type="image/png" sizes="96x96" href="/static/favicon.ico">
    {#
    <link rel="stylesheet" href="/static/css/pages/dashboard1.css"> #}
</head>

<body class="theme-default">
    <script>
        if(localStorage.currentTheme != null)
        {
            let classHolder = document.getElementsByTagName("BODY")[0];
            classHolder.className = localStorage.currentTheme;
        }
    </script>
    <div class="grid-wrapper sidebar-bg bg1">

        <!-- BOF HEADER -->
        <div class="header">
            <div class="header-bar">
                <div class="brand">
                    <a href="{{ url_for('trades.trades_view') }}" class="logo">NO<span class="text-carolina">COIN</span>ER</a>
                    <a href="{{ url_for('trades.trades_view') }}" class="logo-sm text-carolina" style="display: none;">Trades</a>
                </div>
                <div class="btn-toggle">
                    <a href="#" class="toggle-sidebar-btn"><i class="ti-arrow-circle-right"></i></a>
                    <a href="#" class="slide-sidebar-btn" style="display: none;"><i class="ti-menu"></i></a>
                </div>
                <div class="navigation d-flex">

                    <!-- BOF Header Search -->
                    {# <form class="navbar-search" role="search" method="post" action="#">
                        <div class="input-group">
                            <div class="input-group-prepend">
                                <div class="input-group-text"><i class="ti-search"></i></div>
                            </div>
                            <input type="text" placeholder="Search for keywords" class="form-control" name="top-search"
                                id="top-search">
                        </div>
                    </form> #}
                    <!-- EOF Header Search -->

                    <!-- BOF Header Nav -->
                    <div class="navbar-menu d-flex">
                        <div class="menu-item">
                            <a href="#" class="btn right-sidebar-toggle"><i class="ti-user"></i></a>
                        </div>
                    </div>
                    <!-- EOF Header Nav -->

                </div>
            </div>
        </div>
        <!-- EOF HEADER -->

        <!-- BOF ASIDE-LEFT -->
        <div id="sidebar" class="sidebar">
            <div class="sidebar-content">
                {% from "_menu.html" import render_menu %}
                {{ render_menu(current_user) }}
            </div>
        </div>
        <!-- EOF ASIDE-LEFT -->

        <!-- BOF MAIN -->
        <div class="main" style="height: 85vh !important;">
            {% block content %} {% endblock content %}
            <!-- EOF MAIN-BODY -->

        </div>
        <!-- EOF MAIN -->

        <!-- BOF FOOTER -->
        <div class="footer">
            <p class="text-left mt-3">TERMS OF USE: Everything presented here is for <strong>educational purposes only</strong>!
            Owner of this application does not guarantee accuracy of the data or take any responsibility for its use. Cryptocurrency trading is high-risk activity and you could lose you money. By using this application, you agree to stated terms of use.  </p>
            <p class="text-center mt-3">Copyright © 2021 
            <a class="" href="https://forin.v4y.hu/about-us">FOR IN, vl. Branimir Marjanovic</a>. All rights reserved.</p>
        </div>
        <!-- EOF FOOTER -->

        <!-- BOF ASIDE-RIGHT -->
        <div id="sidebar-right">
            <div class="sidebar-right-container">

                <!-- BOF TABS -->
                <ul class="nav nav-tabs">
                    <li class="nav-item">
                        <a href="#tab-1" data-toggle="tab" class="nav-link active">Profile</a>
                    </li>
                </ul>
                <!-- EOF TABS -->

                <!-- BOF TAB PANES -->
                <div class="tab-content">
                    <!-- BOF TAB-PANE #1 -->
                    <div id="tab-1" class="tab-pane show active">
                        <div class="pane-header">
                            <h3><i class="ti-user"></i> User Panel</h3>
                            <i class="fa fa-circle text-success"></i> <span class="profile-user">{{ current_user.first_name }}
                            </span>
                            {% if current_user.is_authenticated %}
                            <span class="float-right"><a href="{{ url_for('user_management.logout') }}" class="text-carolina">Sign Out</a></span>
                            {% else %}
                            <span class="float-right"><a href="{{ url_for('user_management.login') }}" class="text-carolina">Sign In</a></span>
                            {% endif %}
                        </div>
                        <div class="pane-body">
                            <div class="card bg-transparent mb-3">
                                <ul class="list-group list-group-flush">
                                    <li class="list-group-item">
                                        <h5 class="mb-3">My Theme</h5>
                                        <div class="btn-group mb-2">
                                            <button type="button" class="btn switch-theme btn-light"
                                                onclick="localStorage.currentTheme = 'theme-default'"
                                                id="theme-default">Light</button>
                                            <button type="button" class="btn switch-theme btn-dark"
                                                onclick="localStorage.currentTheme = 'theme-dark'"
                                                id="theme-dark">Dark</button>
                                            {# <button type="button" class="btn switch-theme btn-primary"
                                                id="theme-blue">Blue</button> #}
                                        </div>
                                    </li>
                                    {% if current_user.is_authenticated %}
                                    <li class="list-group-item">
                                        <h5 class="mb-3">My Profile</h5>
                                        <form class="form-update-profile">
                                            <div class="form-group row">
                                                <label class="col-form-label col-md-4">Firstname:</label>
                                                <div class="col">
                                                    <input type="text" name="first_name" class="form-control-plaintext"
                                                        value="{{ current_user.first_name }}">
                                                </div>
                                            </div>
                                            <div class="form-group row">
                                                <label class="col-form-label col-md-4">Lastname:</label>
                                                <div class="col">
                                                    <input type="text" name="last_name" class="form-control-plaintext"
                                                        value="{{ current_user.last_name }}">
                                                </div>
                                            </div>
                                            <div class="form-group row">
                                                <label class="col-form-label col-md-4">Email:</label>
                                                <div class="col">
                                                    <input type="text" name="email" class="form-control-plaintext"
                                                        value="{{ current_user.email }}">
                                                </div>
                                            </div>
                                            <div class="form-group row">
                                                <label class="col-form-label col-md-4">Username:</label>
                                                <div class="col">
                                                    <input type="text" name="username" class="form-control-plaintext"
                                                        value="{{ current_user.username }}">
                                                </div>
                                            </div>
                                            {# <div class="form-group row">
                                                <label class="col-form-label col-md-4">Password:</label>
                                                <div class="col">
                                                    <input type="password" name="password"
                                                        class="form-control-plaintext" value="123456789">
                                                </div>
                                            </div>
                                            <div class="col offset-md-4 pl-2">
                                                <button type="submit" class="btn btn-sm btn-primary">Update</button>
                                            </div> #}
                                        </form>
                                    </li>
                                    {% endif %}
                                </ul>
                            </div>
                        </div>
                    </div>
                    <!-- EOF TAB-PANE #1 -->


                </div>
                <!-- EOF TAB PANES -->

            </div>
        </div>
        <!-- EOF ASIDE-RIGHT -->

        <!-- <div id="overlay"></div> -->

        <!-- modal dialog placeholder -->
        <div id="editModal"></div>
        <!-- multiple level modal dialog placeholder -->
        <div id="editModalI"></div>
        <div id="editModalII"></div>
        <div id="editModalIII"></div>
        <!-- inline edit temporary storage for fetched form -->
        <div id="inlineEditModal" style="display: none;">
        </div>


    </div> <!-- END WRAPPER -->

    <script src="/static/siqtheme.js"></script>
    {% block feature_javascripts %} {% endblock feature_javascripts %}
    {# jQueryUI is optional, used for draggable modal #}
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jqueryui/1.12.1/jquery-ui.min.js"></script>
    <script src="/static/app.js?1"></script>
    {% block extra_javascripts %} {% endblock extra_javascripts %}
    <script>
        $(document).ready(function () {
            initDatatable('#datatable');
        });
    </script>
</body>

</html>