{% from "_formhelpers.html" import render_form_fields, validation_summary %}
<div class="modal" id="editModal" tabindex="-1" role="dialog" aria-labelledby="editModalLabel"
    aria-hidden="true" data-backdrop="static" data-focus="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content dialog-size-form">
            <div class="modal-header">
                <h5 class="modal-title" id="editModalLabel">
                    {% if key %}
                        Edit
                    {% else %}
                        Add    
                    {% endif %}
                </h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <form class="validate {{ classes }}" action="" method="POST" novalidate>
                    {% if form_type %}
                        <input type="hidden" name="form_type" value="{{ form_type }}">
                    {% endif %}
                    {% if key %}
                        <input type="hidden" name="key" value="{{ key }}">
                    {% endif %}
                    {{ render_form_fields(form) }}
                </form>
            </div>                        
            <div class="modal-footer">                
                {{ validation_summary(form) }}
                <button id="btnUpdate" type="button" class="btn btn-primary"
                        onclick="submitModal(this,'{{ submit_target }}','#editModal');">Save</button>
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
            </div>
        </div>
    </div>
    <script type="text/javascript" charset="utf-8">
      setupModal();
      $('#editModal').modal('show');
    </script>
</div>