{% extends 'form_base.jinja' %}
{% from "_formhelpers.html" import render_form_fields, render_form_header, render_form_footer %}

{% block modalcontent %}

    <div class="modal-content dialog-size-form">
        {{ render_form_header(key) }}
        <div class="modal-body">
            <form class="validate {{ classes }}" action="" method="POST" novalidate>
                {% if form_type %}
                    <input type="hidden" name="form_type" value="{{ form_type }}">
                {% endif %}
                {% if key %}
                    <input type="hidden" name="key" value="{{ key }}">
                {% endif %}
                {{ render_form_fields(form) }}
            </form>
        </div>
        {{ render_form_footer(submit_target, form) }}
    </div>

{% endblock modalcontent %}
