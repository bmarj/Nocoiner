{% extends 'base.jinja' %}

{% block content %}
  <div class="row">
      <div class="col-lg-12">
          <div class="card mb-3">
              <div class="card-header">
                  <div class="caption uppercase">
                      <i class="ti-layout-grid3-alt"></i> Order Lines View
                  </div>
                  <div class="tools">
                    <button class="btn btn-primary btn-add" onclick="goToEditModal(this, '{{ url_for('.edit', id='') }}', '#editModal')">
                      <i class="ti-write mr-1"></i>Edit</button>
                    {# <button class="btn btn-warning btn-add" onclick="doActionPost(this, '{{ url_for('.cancel_order', id='') }}', '#editModal')"
                            data-confirmation-message="Are you sure you want to cancel this order?"><i class="ti-trash mr-1"></i>Cancel order</button> #}
                  </div>
              </div>
              <div class="card-body">
                  <div class="table-responsive">
                      <table id="datatable" class="table table-bordered table-hover clickable-rows thead" cellspacing="0">
                        <thead class="thead-light"></thead>
                      </table>
                  </div>
              </div>
          </div>
      </div>
  </div>
</div>

<!-- modal dialog placeholder -->
<div class="modal fade" id="editModal" tabindex="-1" role="dialog" aria-labelledby="editModalLabel" aria-hidden="true">
</div>
{% endblock content %}

{% block extra_javascripts %}  
  <script>
    let dtConf = defaultDatatablesConfig;

    dtConf.ajax = '{{ url_for('.order_lines_data') }}';
    dtConf.columns = [
        { data:"sku", title:"SKU" },
        { data:"qty_ordered", title:"Qty Ordered" },
        { data:"qty_shipped", title:"Qty Shipped" },
        { data:"promise_date", title:"Ship by" },
        { data:"line_type", title:"Line Type" },
        { data:"price", title:"Price" },
        { data:"tax", title:"Tax" },
        { data:"order.purchase_date", title:"Purchase Date" },
        { data:"order.sales_channel.description", title:"Sales Channel" },
    ];
    // custom row coloring
    dtConf.fnRowCallback = function( row, data, iDisplayIndex, iDisplayIndexFull ) {
        data.line_type == "S" ? row.classList.add('text-lime') : null;
        data.line_type == "D" ? row.classList.add('table-salmon','text-chili') : null;
    };

    // this function provides API for modal dialog to refresh source grid
    function table_reload() {
      $('#datatable').DataTable().ajax.reload(null, false);
    };

    $(document).ready(function () {
      initDatatable('#datatable', dtConf);
    });
  </script>

{% endblock extra_javascripts %}
