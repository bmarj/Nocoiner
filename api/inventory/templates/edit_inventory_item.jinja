{% from "_formhelpers.html" import render_field, validation_summary %}
<div class="modal" id="editModal" tabindex="-1" role="dialog" aria-labelledby="editModalLabel"
    aria-hidden="true" data-backdrop="static" data-focus="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content dialog-size-form">
            <div class="modal-header">
                <h5 class="modal-title" id="editModalLabel">Edit</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <form class="validate {{ classes }}" action="" method="POST" novalidate>
                  <input type="hidden" name="key" value="{{ key }}">
                  {{ form.hidden_tag() }}
                  {{ render_field(form.Row, class='form-control') }}
                  {{ render_field(form.Level, class='form-control') }}
                  {{ render_field(form.Col, class='form-control') }}
                  {{ render_field(form.Qty, class='form-control') }}
                  {{ render_field(form.UPC, class='form-control') }}
                </form>
            </div>
            <div class="modal-footer">
                {{ validation_summary(form) }}
                <button id="btnUpdate" type="button" class="btn btn-primary"
                        onclick="submitModal(this,'/inventory/update');">Save</button>
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
            </div>
        </div>
    </div>
    <script type="text/javascript" charset="utf-8">
      setupModal();
      showDialog();
    </script>
</div>